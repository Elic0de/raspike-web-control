# Web UI listener
HOST=0.0.0.0
PORT=3000

# UDP telemetry listener on the PC running this app
TELEMETRY_HOST=0.0.0.0
TELEMETRY_PORT=8765

# TCP control bridge on the RasPi
BRIDGE_HOST=<RASPI_IP_ADDRESS>
BRIDGE_PORT=8766
BRIDGE_RETRY_SEC=1

# Optional: force the browser WebSocket endpoint.
# Leave unset to use ws(s)://<current-host>/ws.
# NEXT_PUBLIC_GATEWAY_WS_URL=ws://127.0.0.1:3000/ws

# RasPi Control API MJPEG camera stream proxied by this Web UI server.
# Leave NEXT_PUBLIC_CAMERA_STREAM_URL unset to use /camera/stream.mjpg.
# CAMERA_STREAM_URL defaults to http://${BRIDGE_HOST}:8080/stream.mjpg.
# CAMERA_STREAM_URL=http://<RASPI_IP_ADDRESS>:8080/stream.mjpg
# NEXT_PUBLIC_CAMERA_STREAM_URL=/camera/stream.mjpg

# Optional: comma-separated origins allowed by Next.js dev server.
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.10,raspike.local
